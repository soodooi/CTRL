<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CTRL.KeycapPoolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CTRL"
    xmlns:models="using:CTRL.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="13"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Text="Tap a keycap to invoke. Real wiring lands in W3.7." />

        <ItemsRepeaterScrollHost Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsRepeater ItemsSource="{x:Bind Keycaps, Mode=OneTime}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="76"
                                           MinItemHeight="92"
                                           MinColumnSpacing="8"
                                           MinRowSpacing="12"
                                           MaximumRowsOrColumns="8"
                                           ItemsStretch="Fill" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:Keycap">
                            <Button Click="KeycapButton_Click"
                                    Tag="{x:Bind Id}"
                                    Padding="0"
                                    CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch">
                                <Grid RowSpacing="2" Padding="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{x:Bind Icon}"
                                               FontSize="26"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="1"
                                               Text="{x:Bind Name}"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </ItemsRepeaterScrollHost>
    </Grid>
</Page>
