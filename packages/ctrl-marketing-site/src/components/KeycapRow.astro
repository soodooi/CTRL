---
const caps = [
  { label: "Clip", glyph: "✂", color: "cobalt", hint: "Clipboard AI" },
  { label: "OCR", glyph: "⊡", color: "amber", hint: "Screen → text" },
  { label: "Tr", glyph: "↔", color: "jade", hint: "Translate" },
  { label: "Txt", glyph: "¶", color: "cobalt", hint: "Rewrite" },
  { label: "Ask", glyph: "?", color: "platinum", hint: "Chat" },
];
---

<section class="kcr" aria-label="Sample keycaps">
  <div class="container">
    <ul class="kcr__row" role="list">
      {
        caps.map((cap) => (
          <li class={`kcr__cap kcr__cap--${cap.color}`} title={cap.hint}>
            <span class="kcr__glyph" aria-hidden="true">{cap.glyph}</span>
            <span class="kcr__label">{cap.label}</span>
          </li>
        ))
      }
    </ul>
    <p class="kcr__caption">
      Five built-in keycaps shown. Many more from MCP servers, OAuth platforms,
      local agents, and shared windows.
    </p>
  </div>
</section>

<style>
  .kcr {
    padding-block: clamp(1rem, 0.5rem + 2vw, 3rem) var(--space-16);
  }

  .kcr__row {
    list-style: none;
    margin: 0 0 var(--space-6);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: clamp(var(--space-2), 1.5vw, var(--space-4));
    max-width: 520px;
  }

  @media (max-width: 480px) {
    .kcr__row {
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: var(--space-2);
    }
  }

  .kcr__cap {
    aspect-ratio: 1 / 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--graphite-soft-2), var(--graphite-soft));
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow:
      inset 0 -3px 0 rgba(0, 0, 0, 0.45),
      var(--shadow-md);
    transition: transform var(--duration-fast) var(--ease-out-quart);
  }

  .kcr__cap:hover {
    transform: translateY(-2px);
  }

  .kcr__glyph {
    font-family: var(--font-mono);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: var(--weight-bold);
    line-height: 1;
  }

  .kcr__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--paper-soft);
  }

  .kcr__cap--cobalt .kcr__glyph { color: var(--ctrl-blue-light); }
  .kcr__cap--cobalt { border-top: 2px solid var(--ctrl-blue); }

  .kcr__cap--amber .kcr__glyph { color: var(--keycap-amber); }
  .kcr__cap--amber { border-top: 2px solid var(--keycap-amber); }

  .kcr__cap--jade .kcr__glyph { color: var(--keycap-jade); }
  .kcr__cap--jade { border-top: 2px solid var(--keycap-jade); }

  .kcr__cap--platinum .kcr__glyph { color: var(--keycap-platinum); }
  .kcr__cap--platinum { border-top: 2px solid var(--keycap-platinum); }

  .kcr__caption {
    font-size: var(--text-sm);
    color: var(--ink-faint);
    max-width: 44ch;
  }
</style>
