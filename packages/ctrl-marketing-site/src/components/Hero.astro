---
---

<header class="hero">
  <div class="container">
    <a class="hero__brand" href="/" aria-label="CTRL">
      <span class="hero__brand-bar" aria-hidden="true"></span>
      <span class="hero__brand-text">CTRL</span>
    </a>

    <p class="eyebrow">An AI-native ambient OS hub</p>

    <h1 class="hero__title">
      <span class="hero__word">Share</span>
      <span class="hero__amp" aria-hidden="true">&amp;</span>
      <span class="hero__word hero__word--alt">be shared.</span>
    </h1>

    <p class="hero__sub">
      Press <kbd class="kbd">Ctrl</kbd>. Pick a keycap. Get the AI tool you need —
      and ship your own without writing code.
    </p>

    <div class="hero__cta">
      <a class="btn btn--primary" href="#waitlist">Join the waitlist</a>
      <a class="btn btn--ghost" href="#how">How it works</a>
    </div>
  </div>
</header>

<style>
  .hero {
    padding-block: clamp(4rem, 3rem + 6vw, 9rem) clamp(3rem, 2rem + 4vw, 6rem);
  }

  .hero__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-12);
    font-family: var(--font-display);
    font-weight: var(--weight-black);
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    color: var(--paper);
  }

  .hero__brand-bar {
    display: inline-block;
    width: 28px;
    height: 4px;
    background: var(--ctrl-blue);
    border-radius: 1px;
    box-shadow: var(--shadow-glow-blue);
  }

  .hero__brand-text {
    letter-spacing: 0.04em;
  }

  .hero__title {
    font-size: var(--text-hero);
    line-height: 0.96;
    margin-bottom: var(--space-6);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.18em 0.22em;
  }

  .hero__word {
    color: var(--paper);
  }

  .hero__word--alt {
    color: var(--ctrl-blue-light);
  }

  .hero__amp {
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    color: var(--ink-faint);
    font-style: italic;
    font-size: 0.78em;
    transform: translateY(-0.04em);
  }

  .hero__sub {
    max-width: 38ch;
    font-size: var(--text-lg);
    color: var(--paper-soft);
    margin-bottom: var(--space-8);
  }

  .kbd {
    display: inline-block;
    padding: 0.1em 0.55em;
    font-family: var(--font-mono);
    font-size: 0.9em;
    font-weight: var(--weight-semibold);
    color: var(--paper);
    background: linear-gradient(180deg, var(--graphite-soft-2), var(--graphite-soft));
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      inset 0 -2px 0 rgba(0, 0, 0, 0.35),
      0 1px 0 rgba(255, 255, 255, 0.05);
    transform: translateY(-1px);
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85em 1.6em;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    cursor: pointer;
    transition:
      transform var(--duration-fast) var(--ease-out-quart),
      background var(--duration-fast) var(--ease-out-quart),
      border-color var(--duration-fast) var(--ease-out-quart);
  }

  .btn--primary {
    background: var(--ctrl-blue);
    color: var(--paper);
  }

  .btn--primary:hover {
    background: var(--ctrl-blue-dark);
    color: var(--paper);
    transform: translateY(-1px);
  }

  .btn--ghost {
    background: transparent;
    color: var(--paper);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .btn--ghost:hover {
    color: var(--paper);
    border-color: rgba(255, 255, 255, 0.3);
  }
</style>
