{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CTRL",
  "version": "0.1.0",
  "identifier": "app.ctrl.spike",
  "build": {
    "frontendDist": "../packages/ctrl-web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --workspace @ctrl/web run dev",
    "beforeBuildCommand": "npm --workspace @ctrl/web run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CTRL",
        "width": 920,
        "height": 560,
        "minWidth": 480,
        "minHeight": 420,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": true,
        "center": true,
        "resizable": false,
        "url": "/"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://127.0.0.1:17872 ws://localhost:5173 http://localhost:5173; frame-src 'none'; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
