{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CTRL",
  "version": "0.1.1",
  "identifier": "app.ctrl.spike",
  "build": {
    "frontendDist": "../packages/ctrl-web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --workspace @ctrl/web run dev",
    "beforeBuildCommand": "npm --workspace @ctrl/web run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CTRL",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": false,
        "skipTaskbar": false,
        "focus": true,
        "visible": true,
        "center": true,
        "resizable": true,
        "url": "/"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://127.0.0.1:17872 ws://localhost:5173 http://localhost:5173; frame-src http://127.0.0.1:9119 http://localhost:9119; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "resources": ["../CHANGELOG.md"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Press Ctrl. Get any AI tool.",
    "longDescription": "CTRL is an ambient AI launcher. Tap Ctrl to summon a keycap workspace of curated AI tools — clipboard AI, OCR, translate, MCP tools, and more.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "dmg": {
        "appPosition": { "x": 180, "y": 220 },
        "applicationFolderPosition": { "x": 480, "y": 220 },
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5RjIxNUFFREFBNEE0QTIKUldTaXBLVGFyaFh5YVdUVXRNa284MzdJeU1vZW41eEIzOUFTekY1SXRxK0doYWpEYjBqRDVYeksK",
      "endpoints": [
        "https://github.com/soodooi/CTRL-releases/releases/latest/download/latest.json"
      ]
    }
  }
}
