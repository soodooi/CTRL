{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CTRL",
  "version": "0.1.0",
  "identifier": "app.ctrl.spike",
  "build": {
    "frontendDist": "../packages/ctrl-web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --workspace @ctrl/web run dev",
    "beforeBuildCommand": "npm --workspace @ctrl/web run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CTRL",
        "width": 920,
        "height": 560,
        "minWidth": 480,
        "minHeight": 420,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": false,
        "focus": true,
        "visible": false,
        "resizable": true,
        "url": "/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "app",
    "icon": [],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
