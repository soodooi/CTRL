{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CTRL",
  "version": "0.1.815",
  "identifier": "app.ctrl.spike",
  "build": {
    "frontendDist": "../packages/ctrl-web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --workspace @ctrl/web run dev",
    "beforeBuildCommand": "npm --workspace @ctrl/web run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CTRL",
        "width": 1480,
        "height": 832,
        "minWidth": 1120,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": false,
        "focus": true,
        "visible": true,
        "center": false,
        "resizable": true,
        "url": "/"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: ctrl-asset: http://ctrl-asset.localhost; font-src 'self' data: ctrl-asset: http://ctrl-asset.localhost; connect-src 'self' ipc: http://ipc.localhost ws://127.0.0.1:17872 ws://localhost:5173 http://localhost:5173 http://127.0.0.1:* http://localhost:* ctrl-asset: http://ctrl-asset.localhost; frame-src 'self' http://127.0.0.1:* http://localhost:*; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "resources": {
      "../packages/ctrl-mcps/builtin": "mcps/builtin"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Press Ctrl. Get any AI tool.",
    "longDescription": "CTRL is an ambient AI launcher. Tap Ctrl to summon a mcp workspace of curated AI tools \u2014 clipboard AI, OCR, translate, MCP tools, and more.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "CTRL Dev Signing",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 220
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 220
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5RjIxNUFFREFBNEE0QTIKUldTaXBLVGFyaFh5YVdUVXRNa284MzdJeU1vZW41eEIzOUFTekY1SXRxK0doYWpEYjBqRDVYeksK",
      "endpoints": [
        "https://github.com/soodooi/CTRL-releases/releases/latest/download/latest.json"
      ]
    }
  }
}