{
  "$schema": "https://ctrlapplab.com/schema/design-tokens/v1.json",
  "name": "CTRL Keycap Direction",
  "version": "0.1.0",
  "description": "工业精确派 · Keycap 视觉系统 · macOS 风格",
  "color": {
    "light": {
      "bg": "#F5F5F7",
      "bgElev": "#FFFFFF",
      "card": "#FFFFFF",
      "border": "rgba(0, 0, 0, 0.08)",
      "borderStrong": "rgba(0, 0, 0, 0.14)",
      "text": "#1D1D1F",
      "textMuted": "#6E6E73",
      "textSubtle": "#98989D",
      "primary": "#3B5BDB",
      "primarySoft": "rgba(59, 91, 219, 0.10)",
      "primaryRing": "rgba(59, 91, 219, 0.18)",
      "warm": "#F59F00",
      "cool": "#0CA678",
      "destructive": "#E03131",
      "destructiveSoft": "rgba(224, 49, 49, 0.08)"
    },
    "dark": {
      "bg": "#1D1D1F",
      "bgElev": "#2C2C2E",
      "card": "#2C2C2E",
      "border": "rgba(255, 255, 255, 0.08)",
      "borderStrong": "rgba(255, 255, 255, 0.16)",
      "text": "#F5F5F7",
      "textMuted": "#98989D",
      "textSubtle": "#6E6E73",
      "primary": "#5C7CFA",
      "primarySoft": "rgba(92, 124, 250, 0.14)",
      "primaryRing": "rgba(92, 124, 250, 0.28)",
      "warm": "#FFD43B",
      "cool": "#51CF66",
      "destructive": "#FF6B6B",
      "destructiveSoft": "rgba(255, 107, 107, 0.10)"
    }
  },
  "typography": {
    "fontFamilyUI": "-apple-system, 'Inter', 'PingFang SC', 'Source Han Sans SC', system-ui, sans-serif",
    "fontFamilyMono": "'SF Mono', 'JetBrains Mono', 'Menlo', monospace",
    "size": {
      "xs": "10px",
      "sm": "11px",
      "base": "12px",
      "md": "13px",
      "lg": "14px",
      "xl": "16px",
      "2xl": "18px"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "tracking": {
      "tight": "-0.04em",
      "normal": "-0.005em",
      "wide": "0.02em",
      "widest": "0.12em"
    },
    "lineHeight": {
      "tight": 1.3,
      "normal": 1.5,
      "loose": 1.6
    }
  },
  "spacing": {
    "0": "0",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "14px",
    "5": "16px",
    "6": "24px",
    "7": "32px",
    "8": "48px"
  },
  "radius": {
    "sm": "6px",
    "md": "8px",
    "lg": "10px",
    "window": "14px"
  },
  "shadow": {
    "light": {
      "keycap": "0 1px 0 rgba(255,255,255,0.7) inset, 0 1px 2px rgba(0,0,0,0.04), 0 2px 6px rgba(0,0,0,0.06)",
      "keycapHover": "0 1px 0 rgba(255,255,255,0.85) inset, 0 2px 5px rgba(0,0,0,0.06), 0 6px 14px rgba(0,0,0,0.08)",
      "keycapPress": "0 1px 0 rgba(255,255,255,0.6) inset, 0 -1px 0 rgba(0,0,0,0.04) inset, 0 1px 1px rgba(0,0,0,0.04)",
      "window": "0 0 0 1px rgba(0,0,0,0.04), 0 18px 56px rgba(0,0,0,0.16), 0 4px 12px rgba(0,0,0,0.06)"
    },
    "dark": {
      "keycap": "0 1px 0 rgba(255,255,255,0.06) inset, 0 1px 2px rgba(0,0,0,0.4), 0 2px 6px rgba(0,0,0,0.4)",
      "keycapHover": "0 1px 0 rgba(255,255,255,0.10) inset, 0 2px 5px rgba(0,0,0,0.5), 0 6px 14px rgba(0,0,0,0.5)",
      "keycapPress": "0 1px 0 rgba(255,255,255,0.04) inset, 0 -1px 0 rgba(0,0,0,0.3) inset",
      "window": "0 0 0 1px rgba(0,0,0,0.5), 0 24px 64px rgba(0,0,0,0.6), 0 6px 16px rgba(0,0,0,0.4)"
    }
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "base": "200ms",
      "slow": "320ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "accelerate": "cubic-bezier(0.4, 0, 1, 1)"
    },
    "wakeAnimation": {
      "type": "scale + fade",
      "from": { "transform": "scale(0.96)", "opacity": 0 },
      "to": { "transform": "scale(1)", "opacity": 1 },
      "duration": "180ms",
      "easing": "cubic-bezier(0, 0, 0.2, 1)"
    }
  },
  "logo": {
    "concept": "Keycap shape — left-bottom radius 10px, right-bottom radius 6px (asymmetric for keycap wear feel); amber ↑ glyph at top-right hinting at 'wake / pop'",
    "label": "CTL",
    "labelSemantic": "abbreviation of CTRL printed on keycap face (matches real Mac Control key)"
  }
}
