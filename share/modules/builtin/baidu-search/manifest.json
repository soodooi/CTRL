{
  "$schema": "https://ctrlapplab.com/schema/tool/v1.json",
  "id": "ctrl.builtin.baidu-search",
  "name": "百度搜索",
  "version": "0.1.0",
  "author": {
    "name": "CTRL App Lab",
    "github": "ctrlapplab"
  },
  "description": {
    "short": "用剪贴板内容在百度搜索"
  },
  "icon": "Search",
  "category": "web-browser",
  "tags": [
    "search",
    "browser",
    "chinese"
  ],
  "permissions": [],
  "actions": [
    {
      "id": "search-clipboard",
      "name": "百度搜索剪贴板",
      "description": "打开 baidu.com 搜索",
      "input": "clipboard",
      "output": "browser",
      "scenes": [
        "any-app"
      ],
      "steps": [
        {
          "type": "capture-clipboard",
          "as": "raw"
        },
        {
          "type": "transform",
          "op": "urlencode",
          "input": "{{raw}}",
          "as": "q"
        },
        {
          "type": "open-url",
          "url": "https://www.baidu.com/s?wd={{q}}"
        }
      ]
    }
  ],
  "chord": "sb"
}
