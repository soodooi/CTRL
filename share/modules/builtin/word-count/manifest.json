{
  "$schema": "https://ctrlapplab.com/schema/tool/v1.json",
  "id": "ctrl.builtin.word-count",
  "name": "字数统计",
  "version": "0.1.0",
  "author": {
    "name": "CTRL App Lab",
    "github": "ctrlapplab"
  },
  "description": {
    "short": "统计剪贴板里文本的字符 / 单词 / 行数"
  },
  "icon": "Hash",
  "category": "text-utility",
  "tags": [
    "count",
    "text"
  ],
  "permissions": [
    "clipboard"
  ],
  "actions": [
    {
      "id": "count-clipboard",
      "name": "统计剪贴板字数",
      "description": "字符 / 单词 / 行数",
      "input": "clipboard",
      "output": "modal",
      "scenes": [
        "any-app"
      ],
      "steps": [
        {
          "type": "capture-clipboard",
          "as": "text"
        },
        {
          "type": "transform",
          "op": "wordcount",
          "input": "{{text}}",
          "as": "stats"
        },
        {
          "type": "notify",
          "message": "{{stats}}"
        }
      ]
    }
  ],
  "chord": "wc"
}
