{
  "$schema": "https://ctrlapplab.com/schema/tool/v1.json",
  "id": "ctrl.builtin.lowercase",
  "name": "小写转换",
  "version": "0.1.0",
  "author": {
    "name": "CTRL App Lab",
    "github": "ctrlapplab"
  },
  "description": {
    "short": "把剪贴板里的文本全部转小写"
  },
  "icon": "CaseLower",
  "category": "text-utility",
  "tags": [
    "case",
    "transform"
  ],
  "permissions": [
    "clipboard"
  ],
  "actions": [
    {
      "id": "to-lower",
      "name": "剪贴板转小写",
      "description": "hello world",
      "input": "clipboard",
      "output": "clipboard",
      "scenes": [
        "any-app"
      ],
      "steps": [
        {
          "type": "capture-clipboard",
          "as": "raw"
        },
        {
          "type": "transform",
          "op": "lowercase",
          "input": "{{raw}}",
          "as": "lower"
        },
        {
          "type": "write-clipboard",
          "value": "{{lower}}"
        },
        {
          "type": "notify",
          "message": "→ 小写已写入剪贴板"
        }
      ]
    }
  ],
  "chord": "cl"
}
