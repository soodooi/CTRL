{
  "$schema": "https://ctrlapplab.com/schema/tool/v1.json",
  "id": "ctrl.builtin.quick-ask",
  "name": "Quick Ask",
  "version": "0.1.0",
  "author": {
    "name": "CTRL App Lab",
    "github": "ctrlapplab"
  },
  "description": {
    "short": "Ask the configured LLM a one-shot question — no chat history kept"
  },
  "icon": "MessageCircleQuestion",
  "keycap_color": "cobalt",
  "category": "ai-chat",
  "tags": [
    "ai",
    "ask",
    "chat"
  ],
  "variant": "builtin",
  "target": "mcp-tool",
  "capabilities": {
    "text": { "chat": true }
  },
  "workspace": { "ui": "modal" },
  "permissions": [
    "network"
  ],
  "license": "UNLICENSED",
  "actions": [
    {
      "id": "ask",
      "name": "Ask",
      "description": "Prompt the LLM and show the answer in a modal",
      "input": "prompt",
      "output": "modal",
      "scenes": [
        "any-app"
      ],
      "steps": [
        {
          "type": "llm",
          "system": "You are a concise, factual assistant. Answer the user's question directly in 1-3 sentences. If you don't know, say so plainly.",
          "prompt": "{{input}}",
          "max_tokens": 600,
          "temperature": 0.3,
          "as": "answer"
        },
        {
          "type": "notify",
          "message": "{{answer}}"
        }
      ]
    }
  ],
  "chord": "qa"
}
