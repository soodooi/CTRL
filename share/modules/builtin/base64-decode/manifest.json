{
  "$schema": "https://ctrlapplab.com/schema/tool/v1.json",
  "id": "ctrl.builtin.base64-decode",
  "name": "Base64 解码",
  "version": "0.1.0",
  "author": {
    "name": "CTRL App Lab",
    "github": "ctrlapplab"
  },
  "description": {
    "short": "把剪贴板里的 Base64 字串解码回原文"
  },
  "icon": "Unlock",
  "category": "developer",
  "tags": [
    "base64",
    "decode",
    "auth"
  ],
  "permissions": [
    "clipboard"
  ],
  "actions": [
    {
      "id": "decode-clipboard",
      "name": "Base64 解码剪贴板",
      "description": "Base64 → UTF-8 文本",
      "input": "clipboard",
      "output": "clipboard",
      "scenes": [
        "any-app"
      ],
      "steps": [
        {
          "type": "capture-clipboard",
          "as": "b64"
        },
        {
          "type": "transform",
          "op": "base64decode",
          "input": "{{b64}}",
          "as": "raw"
        },
        {
          "type": "write-clipboard",
          "value": "{{raw}}"
        },
        {
          "type": "notify",
          "message": "→ Base64 解码已写入剪贴板"
        }
      ]
    }
  ],
  "chord": "bd"
}
