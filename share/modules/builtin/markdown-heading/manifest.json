{
  "$schema": "https://ctrlapplab.com/schema/tool/v1.json",
  "id": "ctrl.builtin.markdown-heading",
  "name": "Markdown 标题",
  "version": "0.1.0",
  "author": {
    "name": "CTRL App Lab",
    "github": "ctrlapplab"
  },
  "description": {
    "short": "在剪贴板内容前加 ## 转 H2 标题"
  },
  "icon": "Heading1",
  "category": "markdown-document",
  "tags": [
    "markdown",
    "heading"
  ],
  "permissions": [
    "clipboard"
  ],
  "actions": [
    {
      "id": "to-h2",
      "name": "转 H2 标题",
      "description": "## 你的内容",
      "input": "clipboard",
      "output": "clipboard",
      "scenes": [
        "any-app"
      ],
      "steps": [
        {
          "type": "capture-clipboard",
          "as": "title"
        },
        {
          "type": "template",
          "template": "## {{title}}",
          "as": "wrapped"
        },
        {
          "type": "write-clipboard",
          "value": "{{wrapped}}"
        },
        {
          "type": "notify",
          "message": "→ H2 标题已写入剪贴板"
        }
      ]
    }
  ],
  "chord": "mh"
}
