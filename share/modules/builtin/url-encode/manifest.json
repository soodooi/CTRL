{
  "$schema": "https://ctrlapplab.com/schema/tool/v1.json",
  "id": "ctrl.builtin.url-encode",
  "name": "URL 编码",
  "version": "0.1.0",
  "author": {
    "name": "CTRL App Lab",
    "github": "ctrlapplab"
  },
  "description": {
    "short": "把剪贴板内容做 URL 百分号编码（query string / 嵌特殊字符）"
  },
  "icon": "Link",
  "category": "developer",
  "tags": [
    "url",
    "encode"
  ],
  "permissions": [
    "clipboard"
  ],
  "actions": [
    {
      "id": "encode-clipboard",
      "name": "URL 编码剪贴板",
      "description": "空格 → %20 等",
      "input": "clipboard",
      "output": "clipboard",
      "scenes": [
        "any-app"
      ],
      "steps": [
        {
          "type": "capture-clipboard",
          "as": "raw"
        },
        {
          "type": "transform",
          "op": "urlencode",
          "input": "{{raw}}",
          "as": "encoded"
        },
        {
          "type": "write-clipboard",
          "value": "{{encoded}}"
        },
        {
          "type": "notify",
          "message": "→ URL 编码已写入剪贴板"
        }
      ]
    }
  ],
  "chord": "ue"
}
