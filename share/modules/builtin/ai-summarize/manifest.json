{
  "$schema": "https://ctrlapplab.com/schema/tool/v1.json",
  "id": "ctrl.builtin.ai-summarize",
  "name": "AI 总结",
  "version": "0.1.0",
  "author": {
    "name": "CTRL App Lab",
    "github": "ctrlapplab"
  },
  "description": {
    "short": "用 AI 把剪贴板里的长文总结成 3 句要点（需先在设置配 LLM key）"
  },
  "icon": "Sparkles",
  "category": "ai-summary",
  "tags": [
    "ai",
    "summary"
  ],
  "permissions": [
    "clipboard",
    "network"
  ],
  "actions": [
    {
      "id": "summarize-clipboard",
      "name": "总结剪贴板",
      "description": "调 LLM 用 3 句话总结",
      "input": "clipboard",
      "output": "modal",
      "scenes": [
        "any-app"
      ],
      "steps": [
        {
          "type": "capture-clipboard",
          "as": "raw"
        },
        {
          "type": "llm",
          "system": "你是一个简洁的中文总结助手。输出仅包含 3 个要点，每个一句话，不要其他内容。",
          "prompt": "请用 3 句话总结下面这段内容：\n\n{{raw}}",
          "max_tokens": 400,
          "temperature": 0.3,
          "as": "summary"
        },
        {
          "type": "notify",
          "message": "{{summary}}"
        }
      ]
    }
  ],
  "chord": "as"
}
