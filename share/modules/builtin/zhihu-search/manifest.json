{
  "$schema": "https://ctrlapplab.com/schema/tool/v1.json",
  "id": "ctrl.builtin.zhihu-search",
  "name": "知乎搜索",
  "version": "0.1.0",
  "author": {
    "name": "CTRL App Lab",
    "github": "ctrlapplab"
  },
  "description": {
    "short": "用剪贴板内容在知乎搜索"
  },
  "icon": "MessageCircle",
  "category": "web-browser",
  "tags": [
    "search",
    "zhihu",
    "chinese"
  ],
  "permissions": [],
  "actions": [
    {
      "id": "search-clipboard",
      "name": "知乎搜索剪贴板",
      "description": "打开 zhihu.com 搜索",
      "input": "clipboard",
      "output": "browser",
      "scenes": [
        "any-app"
      ],
      "steps": [
        {
          "type": "capture-clipboard",
          "as": "raw"
        },
        {
          "type": "transform",
          "op": "urlencode",
          "input": "{{raw}}",
          "as": "q"
        },
        {
          "type": "open-url",
          "url": "https://www.zhihu.com/search?q={{q}}&type=content"
        }
      ]
    }
  ],
  "chord": "sz"
}
