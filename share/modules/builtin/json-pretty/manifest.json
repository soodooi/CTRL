{
  "$schema": "https://ctrlapplab.com/schema/tool/v1.json",
  "id": "ctrl.builtin.json-pretty",
  "name": "JSON 美化",
  "version": "0.1.0",
  "author": {
    "name": "CTRL App Lab",
    "github": "ctrlapplab"
  },
  "description": {
    "short": "把剪贴板里的 JSON 格式化为带缩进的可读形式"
  },
  "icon": "Braces",
  "category": "developer",
  "tags": [
    "json",
    "format",
    "debug"
  ],
  "permissions": [
    "clipboard"
  ],
  "actions": [
    {
      "id": "pretty-clipboard",
      "name": "美化剪贴板 JSON",
      "description": "压缩 JSON → 缩进 2 空格",
      "input": "clipboard",
      "output": "clipboard",
      "scenes": [
        "any-app"
      ],
      "steps": [
        {
          "type": "capture-clipboard",
          "as": "raw"
        },
        {
          "type": "transform",
          "op": "jsonpretty",
          "input": "{{raw}}",
          "as": "pretty"
        },
        {
          "type": "write-clipboard",
          "value": "{{pretty}}"
        },
        {
          "type": "notify",
          "message": "→ JSON 已美化并写入剪贴板"
        }
      ]
    }
  ],
  "chord": "jp"
}
