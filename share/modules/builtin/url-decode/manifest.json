{
  "$schema": "https://ctrlapplab.com/schema/tool/v1.json",
  "id": "ctrl.builtin.url-decode",
  "name": "URL 解码",
  "version": "0.1.0",
  "author": {
    "name": "CTRL App Lab",
    "github": "ctrlapplab"
  },
  "description": {
    "short": "把剪贴板里的 URL 百分号编码字符还原"
  },
  "icon": "Unlink",
  "category": "developer",
  "tags": [
    "url",
    "decode"
  ],
  "permissions": [
    "clipboard"
  ],
  "actions": [
    {
      "id": "decode-clipboard",
      "name": "URL 解码剪贴板",
      "description": "%20 → 空格 等",
      "input": "clipboard",
      "output": "clipboard",
      "scenes": [
        "any-app"
      ],
      "steps": [
        {
          "type": "capture-clipboard",
          "as": "raw"
        },
        {
          "type": "transform",
          "op": "urldecode",
          "input": "{{raw}}",
          "as": "decoded"
        },
        {
          "type": "write-clipboard",
          "value": "{{decoded}}"
        },
        {
          "type": "notify",
          "message": "→ URL 解码已写入剪贴板"
        }
      ]
    }
  ],
  "chord": "ud"
}
