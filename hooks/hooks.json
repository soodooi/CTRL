{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pretool-lane-guard.js\"",
            "timeout": 5
          }
        ],
        "description": "Olym lane-guard — block writes outside the worker's lane unless allowlisted or covered by active handoff"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session-handoff-snapshot.js\"",
            "timeout": 10
          }
        ],
        "description": "Olym three-column injection — inject active handoffs / fleet status / messages on session start"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/stop-handoffs-archive.js\"",
            "timeout": 10
          }
        ],
        "description": "Olym auto-archive — sweep done/verified handoffs on session end (main branch + clean tree only)"
      }
    ]
  }
}
