#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Multi-agent fleet: keep .kiro/handoffs/INDEX.md in sync with H-*.md frontmatter.
# If any handoff file is staged, regenerate INDEX and re-add it to the commit.
# (See .kiro/specs/multi-agent-fleet/spec.md §7.5)

if git diff --cached --name-only --diff-filter=ACMR | grep -qE '^\.kiro/handoffs/(H-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]+.*\.md|_template\.md)$'; then
  node scripts/handoffs-index.js
  git add .kiro/handoffs/INDEX.md
fi

# Spec discipline: keep .kiro/specs/_index.md in sync with spec frontmatter.
# If any .md under .kiro/specs/ is staged, regenerate. (Re-staging only _index.md is a no-op.)
# (See .kiro/steering/protocol/spec-discipline.md)
if git diff --cached --name-only --diff-filter=ACMR | grep -qE '^\.kiro/specs/.*\.md$'; then
  node scripts/specs-index.mjs
  git add .kiro/specs/_index.md
fi

# Note: dike skill change enforcement moved to commit-msg hook (which receives the message).
# pre-commit doesn't see commit message in -m mode (timing issue).
