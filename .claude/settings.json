{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run test:*)",
      "Bash(npm run format:*)",
      "Bash(ls:*)",
      "Bash(node:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(gh:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(pwd:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(head:*)",
      "Bash(tail:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout -- .)"
    ],
    "additionalDirectories": []
  },
  "language": "chinese",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/pretool-lane-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "STEP 1 (do this FIRST): Extract file_path from $ARGUMENTS. If the path contains '/.olym/' OR '/.claude/' OR ends with '/CLAUDE.md' OR ends with '/README.md' OR is a .md file under docs/specs/handoffs/best-practice/reports/plans/resources, respond IMMEDIATELY with {\"decision\":\"approve\",\"reason\":\"documentation path — free-form prose allowed\"} and STOP.\n\nSTEP 2 (only if path NOT whitelisted): Check if this file edit introduces any of these violations in actual source code (.js/.ts/.vue/.jsx/.tsx/.go/.py/.json/.toml): 1) Hardcoding API keys or secrets (literal Bearer tokens, API_KEY=..., client_secret literals — NOT environment variable references). 2) Non-English text in code files (comments, strings, error messages — Chinese in .md files is always allowed). 3) Project-specific banned patterns from your CLAUDE.md (extend this prompt for your project). If any violation found, respond with {\"decision\":\"block\",\"reason\":\"<which violation, with line reference>\"}. Otherwise respond with {\"decision\":\"approve\"}.\n\nInput: $ARGUMENTS"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/verification-gate.cjs\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/adr-cite-gate.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/memory-load-injector.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"Before compacting: preserve current task context, file paths being edited, and any pending git changes.\"}'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-handoff-snapshot.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-handoffs-archive.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true
}
